@model IEnumerable<EmployeeTaskProgress.Models.TaskItem>

@{
    ViewData["Title"] = "Tasks Directory";
}

<div class="container-fluid py-4">
    <div class="adaptive-header p-4 rounded-4 shadow-sm mb-4 border-bottom border-primary border-opacity-10">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h2 class="fw-bold adaptive-text mb-1">Tasks Directory</h2>
                <p class="adaptive-muted mb-0 small">Track and manage daily employee activities</p>
            </div>
            <div class="col-md-6 text-md-end mt-3 mt-md-0">
                <div class="btn-group me-3 shadow-sm p-1 bg-adaptive-light rounded-3 border border-opacity-10">
                    <button type="button" class="btn btn-sm filter-btn active" onclick="filterTasks('all', this)">All</button>
                    <button type="button" class="btn btn-sm filter-btn" onclick="filterTasks('today', this)">Today</button>
                    <button type="button" class="btn btn-sm filter-btn" onclick="filterTasks('week', this)">This Week</button>
                </div>

                <a href="/Task/Create" class="btn btn-primary shadow-sm px-4 rounded-3">
                    <i class="bi bi-plus-lg me-2"></i>Add New Task
                </a>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden adaptive-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="taskTable">
                    <thead class="bg-adaptive-light text-uppercase">
                        <tr>
                            <th class="ps-4 py-3 adaptive-text opacity-75 small fw-bold" style="width: 80px;">ID</th>
                            <th class="py-3 adaptive-text opacity-75 small fw-bold">Task Description</th>
                            <th class="py-3 adaptive-text opacity-75 small fw-bold">Project</th>
                            <th class="py-3 adaptive-text opacity-75 small fw-bold">Date & Time</th>
                            <th class="py-3 adaptive-text opacity-75 small fw-bold text-center" style="width: 200px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="task-row" data-date="@item.TaskDateTime.ToString("yyyy-MM-dd")">
                                <td class="ps-4">
                                    <span class="badge bg-adaptive-light adaptive-text border border-opacity-10 px-2 py-1 rounded-2 fw-normal">
                                        #@item.Id
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm me-3 bg-soft-indigo text-indigo rounded-circle d-flex align-items-center justify-content-center">
                                            <i class="bi bi-card-checklist"></i>
                                        </div>
                                        <span class="fw-semibold adaptive-text">@item.Description</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-soft-success text-success px-3 py-2 rounded-pill fw-medium">
                                        <i class="bi bi-folder2 me-1"></i> @item.Project.ProjectName
                                    </span>
                                </td>
                                <td>
                                    <div class="small fw-bold adaptive-text mb-1">
                                        <i class="bi bi-calendar3 me-1 adaptive-muted"></i> @item.TaskDateTime.ToString("dd MMM, yyyy")
                                    </div>
                                    <div>
                                        <span class="badge bg-soft-indigo text-indigo time-slot-badge px-2 py-1">
                                            <i class="bi bi-clock-fill me-1" style="font-size: 0.75rem;"></i>
                                            @item.TaskDateTime.ToString("hh tt") - @item.EndDateTime.ToString("hh tt")
                                        </span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group gap-2">
                                        <a href="/Task/Edit/@item.Id" class="btn btn-outline-warning btn-sm rounded-2 px-3 action-btn">
                                            <i class="bi bi-pencil-square me-1"></i> Edit
                                        </a>
                                        <a href="/Task/Delete/@item.Id" class="btn btn-outline-danger btn-sm rounded-2 px-3 action-btn"
                                           onclick="return confirm('Are you sure you want to delete this task?')">
                                            <i class="bi bi-trash3 me-1"></i> Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div id="noDataMessage" class="text-center py-5">
            <i class="bi bi-clipboard-x display-1 text-muted opacity-25"></i>
            <h4 class="text-muted">No tasks recorded yet</h4>
        </div>
    }
</div>

<style>
    /* --- Lush Adaptive Styles --- */
    .adaptive-header {
        background: linear-gradient(135deg, #f8faff 0%, #ffffff 100%) !important;
        transition: all 0.3s ease;
    }

    .adaptive-card {
        background-color: #ffffff !important;
    }

    .adaptive-text {
        color: #1362b1 !important;
    }

    .adaptive-muted {
        color: #5a7184 !important;
    }

    .bg-adaptive-light {
        background-color: #f1f4f9 !important;
    }

    /* --- Dark Mode Overrides --- */
    [data-theme="dark"] .adaptive-header,
    .dark-mode .adaptive-header,
    [data-theme="dark"] .adaptive-card,
    .dark-mode .adaptive-card {
        background: #242424 !important;
        border: none !important;
    }

    [data-theme="dark"] .adaptive-text,
    .dark-mode .adaptive-text {
        color: #f8f9fa !important;
    }

    [data-theme="dark"] .adaptive-muted,
    .dark-mode .adaptive-muted {
        color: #adb5bd !important;
    }

    [data-theme="dark"] .bg-adaptive-light,
    .dark-mode .bg-adaptive-light {
        background-color: #2d2d2d !important;
    }

    /* --- Indigo & Success Accents --- */
    .bg-soft-indigo {
        background-color: rgba(102, 16, 242, 0.08) !important;
    }

    .text-indigo {
        color: #6610f2 !important;
    }

    .time-slot-badge {
        border: 1px solid rgba(102, 16, 242, 0.15) !important;
        font-weight: 600 !important;
    }

    .bg-soft-success {
        background-color: rgba(25, 135, 84, 0.1) !important;
        color: #198754 !important;
    }

    /* --- Filter Buttons --- */
    .filter-btn {
        padding: 5px 15px;
        border: none !important;
        color: #6c757d;
        font-weight: 500;
        border-radius: 6px !important;
        transition: all 0.2s;
    }

    [data-theme="dark"] .filter-btn,
    .dark-mode .filter-btn {
        color: #adb5bd;
    }

    .filter-btn.active {
        background-color: #6610f2 !important;
        color: white !important;
        box-shadow: 0 4px 12px rgba(102, 16, 242, 0.25);
    }

    /* --- General UI --- */
    .avatar-sm {
        width: 35px;
        height: 35px;
        font-weight: bold;
    }

    .table tbody tr:hover {
        background-color: rgba(102, 16, 242, 0.02) !important;
    }

    .action-btn:hover {
        transform: translateY(-2px);
    }
</style>

@section Scripts {
    <script>
        function filterTasks(period, element) {
            const rows = document.querySelectorAll('.task-row');
            const now = new Date();
            const todayStr = now.toISOString().split('T')[0];

            // Calculate Monday of current week
            const day = now.getDay();
            const diff = now.getDate() - day + (day === 0 ? -6 : 1);
            const startOfWeek = new Date(now.setDate(diff));
            startOfWeek.setHours(0,0,0,0);

            // Update UI
            document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
            element.classList.add('active');

            rows.forEach(row => {
                const rowDateStr = row.getAttribute('data-date');
                const rowDate = new Date(rowDateStr);
                rowDate.setHours(0,0,0,0);

                if (period === 'all') {
                    row.style.display = '';
                } else if (period === 'today') {
                    row.style.display = (rowDateStr === todayStr) ? '' : 'none';
                } else if (period === 'week') {
                    const todayCheck = new Date();
                    todayCheck.setHours(23,59,59,999);
                    row.style.display = (rowDate >= startOfWeek && rowDate <= todayCheck) ? '' : 'none';
                }
            });
        }
    </script>
}