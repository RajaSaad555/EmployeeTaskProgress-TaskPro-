@model EmployeeTaskProgress.Models.TaskItem

@{
    ViewData["Title"] = "Edit Task";
}

<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">
            
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                
                <div class="card-header bg-warning bg-gradient p-4 border-0" style="background: linear-gradient(45deg, #f39c12, #d35400) !important;">
                    <div class="d-flex align-items-center text-white">
                        <div class="bg-white bg-opacity-25 rounded-circle p-3 me-3">
                            <i class="bi bi-pencil-square fs-3"></i>
                        </div>
                        <div>
                            <h3 class="mb-0 fw-bold">Modify Task Entry</h3>
                            <p class="mb-0 small opacity-75">Updating details for Task ID: #@Model.Id</p>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    <form asp-action="Edit" method="post" class="needs-validation">
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-4">
                            <label asp-for="TaskDateTime" class="form-label fw-bold text-secondary">
                                <i class="bi bi-clock-history me-1"></i> Task Date & Time
                            </label>
                            <input asp-for="TaskDateTime" type="datetime-local" class="form-control form-control-lg bg-light border-0 shadow-none lush-input" required />
                            <span asp-validation-for="TaskDateTime" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ProjectId" class="form-label fw-bold text-secondary">
                                <i class="bi bi-folder-check me-1"></i> Change Project
                            </label>
                            <select asp-for="ProjectId" asp-items="ViewBag.Projects" class="form-select form-select-lg bg-light border-0 shadow-none lush-input cursor-pointer" required>
                                <option value="" disabled>-- Assign to Project --</option>
                            </select>
                            <span asp-validation-for="ProjectId" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold text-secondary">
                                <i class="bi bi-card-text me-1"></i> Task Description
                            </label>
                            <textarea asp-for="Description" class="form-control bg-light border-0 shadow-none lush-input" 
                                      rows="4" placeholder="Update task details..." required></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <hr class="my-4 opacity-10">

                        <div class="d-flex flex-column flex-sm-row gap-3">
                            <a href="/Task/index" class="btn btn-light btn-lg flex-grow-1 fw-semibold text-muted border py-3 shadow-sm hover-red">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-warning btn-lg flex-grow-1 fw-bold py-3 shadow-sm text-white hover-glow">
                                <i class="bi bi-check-all me-2"></i>Update Task
                            </button>
                        </div>

                    </form>
                </div>
            </div>

            <div class="text-center mt-3">
                <span class="badge bg-soft-warning text-dark border border-warning border-opacity-25 px-3 py-2 rounded-pill small">
                    <i class="bi bi-info-circle me-1"></i> Note: This will update the log for the selected project.
                </span>
            </div>
        </div>
    </div>
</div>

<style>
    /* Consistent Lush Styles */
    .lush-input {
        border-radius: 12px !important;
        padding: 12px 15px;
        transition: all 0.3s ease;
    }

    .lush-input:focus {
        background-color: #fff !important;
        border: 1px solid #f39c12 !important;
        box-shadow: 0 0 15px rgba(243, 156, 18, 0.1) !important;
    }

    .btn-warning {
        background: linear-gradient(45deg, #f39c12, #e67e22);
        border: none;
    }

    .hover-glow:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(243, 156, 18, 0.3) !important;
    }

    .hover-red:hover {
        background-color: #fff5f5 !important;
        color: #dc3545 !important;
        border-color: #dc3545 !important;
    }

    .bg-soft-warning {
        background-color: rgba(255, 193, 7, 0.1);
    }

    .cursor-pointer { cursor: pointer; }

    /* Entry Animation */
    .card {
        animation: fadeInRight 0.4s ease-out;
    }

    @@keyframes fadeInRight {
        from { opacity: 0; transform: translateX(20px); }
        to { opacity: 1; transform: translateX(0); }
    }
</style>