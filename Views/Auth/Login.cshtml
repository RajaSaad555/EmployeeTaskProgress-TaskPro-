@{
    ViewData["Title"] = "Login";
    Layout = null; // Is se Sidebar aur baaki layout hat jayega
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Task Manager Pro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body {
            background: linear-gradient(135deg, #6610f2 0%, #4e73df 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Poppins', sans-serif;
        }

        .login-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
            padding: 40px;
            width: 100%;
            max-width: 400px;
        }

        .lush-input {
            border-radius: 10px;
            padding: 12px;
            background-color: #f8f9fc;
            border: 1px solid #e3e6f0;
        }

            .lush-input:focus {
                box-shadow: 0 0 10px rgba(102, 16, 242, 0.1);
                border-color: #6610f2;
            }

        .btn-login {
            background: #6610f2;
            border: none;
            border-radius: 10px;
            padding: 12px;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-login:hover {
                background: #520dc2;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(102, 16, 242, 0.3);
            }

        .brand-logo {
            width: 60px;
            height: 60px;
            background: #f1f3f9;
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            color: #6610f2;
            font-size: 24px;
        }
    </style>
</head>
<body>

    <div class="login-card text-center">
        <div class="brand-logo">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        <h3 class="fw-bold text-dark mb-2">Welcome Back</h3>
        <p class="text-muted small mb-4">Please enter your details to login</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2 small border-0 shadow-sm" style="border-radius: 10px;">
                <i class="bi bi-exclamation-triangle me-2"></i> @ViewBag.Error
            </div>
        }

        <form method="post" class="text-start">
            <div class="mb-3">
                <label class="form-label small fw-bold text-secondary">Email Address</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0" style="border-radius: 10px 0 0 10px;">
                        <i class="bi bi-envelope text-muted"></i>
                    </span>
                    <input name="Email" type="email" class="form-control lush-input border-start-0"
                           placeholder="name@example.com" style="border-radius: 0 10px 10px 0;" required />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label small fw-bold text-secondary">Password</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0" style="border-radius: 10px 0 0 10px;">
                        <i class="bi bi-lock text-muted"></i>
                    </span>
                    <input name="password" type="password" class="form-control lush-input border-start-0"
                           placeholder="••••••••" style="border-radius: 0 10px 10px 0;" required />
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-login w-100 mb-3 text-white">
                Sign In
            </button>
        </form>

        <p class="text-muted small mb-0">System Version 2.0</p>
    </div>

</body>
</html>