@model IEnumerable<EmployeeTaskProgress.Models.Project>

@{
    ViewData["Title"] = "Projects List";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 adaptive-header p-4 rounded-4 shadow-sm border-bottom border-primary border-opacity-10">
        <div>
            <h2 class="fw-bold adaptive-text mb-0">Projects Directory</h2>
            <p class="adaptive-muted mb-0 small">Manage and monitor all active projects</p>
        </div>
        <a href="/Project/Create" class="btn btn-primary btn-lg shadow-sm px-4 rounded-3">
            <i class="bi bi-plus-lg me-2"></i>Add New Project
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden adaptive-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 adaptive-table">
                    <thead class="bg-adaptive-light text-uppercase">
                        <tr>
                            <th class="ps-4 py-3 adaptive-text opacity-75 small fw-bold" style="width: 100px;">ID</th>
                            <th class="py-3 adaptive-text opacity-75 small fw-bold">Project Name</th>
                            <th class="py-3 adaptive-text opacity-75 small fw-bold">Assigned Client</th>
                            <th class="py-3 adaptive-text opacity-75 small fw-bold text-center" style="width: 200px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="badge bg-adaptive-light adaptive-text border border-opacity-10 px-3 py-2 rounded-3 fw-normal">
                                        #@item.Id
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm me-3 bg-soft-success text-success rounded-circle d-flex align-items-center justify-content-center">
                                            @item.ProjectName.Substring(0, 1).ToUpper()
                                        </div>
                                        <span class="fw-semibold adaptive-text fs-5">@item.ProjectName</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-soft-primary text-primary px-3 py-2 rounded-pill fw-medium">
                                        <i class="bi bi-person me-1"></i> @item.Client.ClientName
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group gap-2">
                                        <a href="/Project/Edit/@item.Id" class="btn btn-outline-warning btn-sm rounded-2 px-3 action-btn">
                                            <i class="bi bi-pencil-square me-1"></i> Edit
                                        </a>
                                        <a href="/Project/Delete/@item.Id" class="btn btn-outline-danger btn-sm rounded-2 px-3 action-btn"
                                           onclick="return confirm('Are you sure you want to delete this project?')">
                                            <i class="bi bi-trash3 me-1"></i> Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-folder-x display-1 text-muted opacity-25"></i>
            <h4 class="text-muted">No projects found</h4>
        </div>
    }
</div>

<style>
    /* --- Lush Light Mode Styles --- */
    .adaptive-header {
        background: linear-gradient(135deg, #f8faff 0%, #ffffff 100%) !important;
        border: 1px solid #eef2f6 !important;
    }

    .adaptive-card {
        background-color: #ffffff !important;
        transition: all 0.3s ease;
    }

    .adaptive-text {
        color: #1362b1 !important; /* Premium Blue */
    }

    .adaptive-muted {
        color: #5a7184 !important;
    }

    .bg-adaptive-light {
        background-color: #f1f4f9 !important;
    }

    /* --- Dark Mode Overrides --- */
    [data-theme="dark"] .adaptive-header,
    .dark-mode .adaptive-header,
    [data-theme="dark"] .adaptive-card,
    .dark-mode .adaptive-card {
        background: #242424 !important;
        border: none !important;
    }

    [data-theme="dark"] .adaptive-text,
    .dark-mode .adaptive-text {
        color: #f8f9fa !important;
    }

    [data-theme="dark"] .adaptive-muted,
    .dark-mode .adaptive-muted {
        color: #adb5bd !important;
    }

    [data-theme="dark"] .bg-adaptive-light,
    .dark-mode .bg-adaptive-light {
        background-color: #2d2d2d !important;
    }

    /* --- UI Elements --- */
    .bg-soft-primary {
        background-color: rgba(19, 98, 177, 0.1) !important;
        color: #1362b1 !important;
    }

    .bg-soft-success {
        background-color: rgba(25, 135, 84, 0.1) !important;
        color: #198754 !important;
    }

    .avatar-sm {
        width: 40px;
        height: 40px;
        font-weight: bold;
    }

    .table tbody tr:hover {
        background-color: rgba(19, 98, 177, 0.02) !important;
    }

    .action-btn {
        transition: all 0.2s;
        border-width: 1.5px;
    }

        .action-btn:hover {
            transform: translateY(-2px);
        }
</style>