@model EmployeeTaskProgress.Models.Client

@{
    ViewData["Title"] = "Add Client";
}

<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary bg-gradient text-white p-4 border-0">
                    <div class="d-flex align-items-center">
                        <div class="bg-white bg-opacity-25 rounded-circle p-3 me-3">
                            <i class="bi bi-person-plus-fill fs-3"></i>
                        </div>
                        <div>
                            <h3 class="mb-0 fw-bold">Add New Client</h3>
                            <p class="mb-0 small opacity-75">Register a new client to the system</p>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    <form method="post" class="needs-validation">

                        <div class="mb-4">
                            <label asp-for="ClientName" class="form-label fw-semibold text-secondary">Client Name</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-muted">
                                    <i class="bi bi-building"></i>
                                </span>
                                <input asp-for="ClientName" class="form-control form-control-lg border-start-0 bg-light shadow-none custom-input"
                                       placeholder="e.g. Acme Corp" required />
                            </div>
                            <span asp-validation-for="ClientName" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-5">
                            <a href="/Client/index" class="btn btn-light btn-lg px-4 fw-semibold text-muted border">
                                <i class="bi bi-arrow-left me-2"></i>Back
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg px-5 fw-bold shadow-sm">
                                <i class="bi bi-check-circle me-2"></i>Save Client
                            </button>
                        </div>

                    </form>
                </div>
            </div>

            <p class="text-center text-muted mt-4 small">
                <i class="bi bi-info-circle me-1"></i> Make sure the client name is unique for better tracking.
            </p>
        </div>
    </div>
</div>

<style>
    /* Lush Customizations */
    .custom-input:focus {
        background-color: #fff !important;
        border-color: #0d6efd !important;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1) !important;
    }

    .input-group-text {
        border-radius: 10px 0 0 10px !important;
    }

    .form-control {
        border-radius: 0 10px 10px 0 !important;
    }

    .btn {
        border-radius: 10px;
        transition: all 0.3s ease;
    }

    .btn-primary {
        background: linear-gradient(45deg, #0d6efd, #0043a8);
        border: none;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(13, 110, 253, 0.3);
        }

    .card {
        animation: fadeInUp 0.5s ease-out;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>