@model IEnumerable<EmployeeTaskProgress.Models.Client>

@{
    ViewData["Title"] = "Clients List";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 adaptive-header p-4 rounded-4 shadow-sm border-bottom border-primary border-opacity-10">
        <div>
            <h2 class="fw-bold adaptive-text mb-0">Clients Directory</h2>
            <p class="adaptive-muted mb-0 small">Manage and monitor all registered clients</p>
        </div>
        <a href="/Client/Create" class="btn btn-primary btn-lg shadow-sm px-4 rounded-3">
            <i class="bi bi-plus-lg me-2"></i>Add New Client
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden adaptive-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 adaptive-table">
                    <thead class="bg-adaptive-light text-uppercase">
                        <tr>
                            <th class="ps-4 py-3 adaptive-text opacity-75 small fw-bold" style="width: 100px;">ID</th>
                            <th class="py-3 adaptive-text opacity-75 small fw-bold">Client Name</th>
                            <th class="py-3 adaptive-text opacity-75 small fw-bold text-center" style="width: 200px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="badge bg-adaptive-light adaptive-text border border-opacity-10 px-3 py-2 rounded-3 fw-normal">
                                        #@item.Id
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm me-3 bg-soft-primary text-primary rounded-circle d-flex align-items-center justify-content-center">
                                            @item.ClientName.Substring(0, 1).ToUpper()
                                        </div>
                                        <span class="fw-semibold adaptive-text fs-5">@item.ClientName</span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group gap-2">
                                        <a href="/Client/Edit/@item.Id" class="btn btn-outline-warning btn-sm rounded-2 px-3 action-btn">
                                            <i class="bi bi-pencil-square me-1"></i> Edit
                                        </a>
                                        <a href="/Client/Delete/@item.Id" class="btn btn-outline-danger btn-sm rounded-2 px-3 action-btn"
                                           onclick="return confirm('Are you sure you want to delete this client?')">
                                            <i class="bi bi-trash3 me-1"></i> Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    /* --- Light Mode Enhancements --- */

    /* Header background: Halka sa blue/white gradient for Lush look */
    .adaptive-header {
        background: linear-gradient(135deg, #f8faff 0%, #ffffff 100%) !important;
        border: 1px solid #eef2f6 !important;
    }

    .adaptive-card {
        background-color: #ffffff !important;
    }

    /* Aapka favorite blue color headers ke liye */
    .adaptive-text {
        color: #1362b1 !important;
    }

    .adaptive-muted {
        color: #5a7184 !important;
    }

    .bg-adaptive-light {
        background-color: #f1f4f9 !important;
    }

    /* --- Dark Mode Override --- */
    [data-theme="dark"] .adaptive-header,
    .dark-mode .adaptive-header,
    [data-theme="dark"] .adaptive-card,
    .dark-mode .adaptive-card {
        background: #242424 !important;
        border: none !important;
    }

    [data-theme="dark"] .adaptive-text,
    .dark-mode .adaptive-text {
        color: #f8f9fa !important;
    }

    [data-theme="dark"] .adaptive-muted,
    .dark-mode .adaptive-muted {
        color: #adb5bd !important;
    }

    [data-theme="dark"] .bg-adaptive-light,
    .dark-mode .bg-adaptive-light {
        background-color: #2d2d2d !important;
    }

    /* Avatar Styling */
    .avatar-sm {
        width: 40px;
        height: 40px;
        font-weight: bold;
    }

    .bg-soft-primary {
        background-color: rgba(19, 98, 177, 0.1) !important;
        color: #1362b1 !important;
    }
</style>