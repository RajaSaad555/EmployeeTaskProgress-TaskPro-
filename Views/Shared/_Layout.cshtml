<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Task Manager Pro</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        :root {
            --primary-color: #4e73df;
            --secondary-color: #6610f2;
            --sidebar-bg: #1a1c23;
            --body-bg: #f8f9fc;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: var(--body-bg);
            color: #333;
            overflow-x: hidden;
        }

        /* Sidebar Styles */
        #sidebar {
            min-width: 260px;
            max-width: 260px;
            min-height: 100vh;
            background: var(--sidebar-bg);
            transition: all 0.3s;
            position: fixed;
            z-index: 1000;
        }

            #sidebar .sidebar-header {
                padding: 20px;
                background: rgba(255, 255, 255, 0.05);
                border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            }

            #sidebar ul li a {
                padding: 12px 20px;
                display: flex;
                align-items: center;
                color: #adb5bd;
                text-decoration: none;
                transition: 0.3s;
                border-radius: 8px;
                margin: 4px 15px;
            }

                /* Active & Hover State - Lush Effect */
                #sidebar ul li a:hover,
                #sidebar ul li a.active {
                    color: #fff !important;
                    background: #6610f2 !important; /* Active Indigo Background */
                    box-shadow: 0 4px 12px rgba(102, 16, 242, 0.3);
                    transform: translateX(5px);
                }

                #sidebar ul li a i {
                    margin-right: 12px;
                    font-size: 1.1rem;
                }

        /* Content Area */
        #content {
            width: calc(100% - 260px);
            margin-left: 260px;
            min-height: 100vh;
            transition: all 0.3s;
        }

        .top-navbar {
            background: #fff;
            padding: 15px 30px;
            border-bottom: 1px solid #e3e6f0;
            box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.05);
        }

        .main-container {
            padding: 30px;
        }

        /* Responsive */
        @@media (max-width: 992px) {
            #sidebar {
                margin-left: -260px;
            }

                #sidebar.active {
                    margin-left: 0;
                }

            #content {
                width: 100%;
                margin-left: 0;
            }
        }

        /* Dark Theme Support */
        [data-bs-theme="dark"] {
            --body-bg: #121212;
            --sidebar-bg: #000000;
        }

            [data-bs-theme="dark"] .top-navbar {
                background-color: #1e1e1e !important;
                border-color: #333 !important;
            }

            [data-bs-theme="dark"] .text-dark {
                color: #ffffff !important;
            }
    </style>
</head>
<body>

    <div class="d-flex">
        <nav id="sidebar">
            <div class="sidebar-header">
                <h4 class="text-white fw-bold mb-0">
                    <i class="bi bi-shield-check me-2 text-primary"></i>TaskPro
                </h4>
            </div>

            <ul class="list-unstyled mt-3" id="sidebarMenu">
                <li>
                    <a asp-controller="Dashboard" asp-action="Index">
                        <i class="bi bi-grid-1x2-fill"></i> Dashboard
                    </a>
                </li>
                <li>
                    <a asp-controller="Client" asp-action="Index">
                        <i class="bi bi-people-fill"></i> Clients
                    </a>
                </li>
                <li>
                    <a asp-controller="Project" asp-action="Index">
                        <i class="bi bi-kanban-fill"></i> Projects
                    </a>
                </li>
                <li>
                    <a asp-controller="Task" asp-action="Index">
                        <i class="bi bi-calendar-check-fill"></i> Tasks
                    </a>
                </li>
                <li>
                    <a asp-controller="Report" asp-action="Reports">
                        <i class="bi bi-calendar-check-fill"></i> Reports
                    </a>
                </li>
                <li>
                    <a asp-controller="Task" asp-action="Calendar">
                        <i class="bi bi-calendar-week"></i> Calendar View
                    </a>
                </li>
                <li>
                    <a asp-controller="User" asp-action="Index">
                        <i class="bi bi-person-gear"></i> Manage Users
                    </a>
                </li>
                <hr class="text-secondary mx-3 opacity-25">
                <li>
                    <a href="/setting/Index">
                        <i class="bi bi-gear-fill"></i> Settings
                    </a>
                </li>
            </ul>
        </nav>

        <div id="content">
            <nav class="navbar navbar-expand-lg top-navbar">
                <div class="container-fluid">
                    <button type="button" id="sidebarCollapse" class="btn btn-light border d-lg-none">
                        <i class="bi bi-list"></i>
                    </button>

                    <div class="ms-auto d-flex align-items-center">
                        <div class="dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center p-0" href="#" role="button" data-bs-toggle="dropdown">
                                <div class="avatar-sm rounded-circle d-flex align-items-center justify-content-center me-2 shadow-sm" style="width:38px; height:38px; background-color: #6610f2; color:white;">
                                    <i class="bi bi-person-fill"></i>
                                </div>
                                <div class="d-none d-md-block text-start">
                                    <p class="mb-0 fw-bold small text-dark lh-1">Admin Account</p>
                                    <small class="text-muted" style="font-size: 0.7rem;">Administrator</small>
                                </div>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 mt-2">
                                <li><a class="dropdown-item py-2 text-danger" asp-controller="Auth" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i> Logout</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>

            <div class="main-container">
                <main role="main">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            // Sidebar Toggle for Mobile
            $('#sidebarCollapse').on('click', function () {
                $('#sidebar').toggleClass('active');
            });

            // --- Active Menu Script ---
            var currentUrl = window.location.pathname;

            $('#sidebarMenu li a').each(function () {
                var linkUrl = $(this).attr('href');

                // Agar URL match kare (Home page ke liye exact match, baaki ke liye partial)
                if (currentUrl === linkUrl || (linkUrl !== '/' && currentUrl.startsWith(linkUrl))) {
                    $(this).addClass('active');
                } else {
                    $(this).removeClass('active');
                }
            });
        });

        // Apply Dark Mode if saved
        if (localStorage.getItem('theme') === 'dark') {
            document.body.setAttribute('data-bs-theme', 'dark');
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>