@{
    ViewData["Title"] = "System Settings";
}

<div class="container-fluid py-4">
    <div class="adaptive-header p-4 rounded-4 shadow-sm mb-4 border-bottom border-primary border-opacity-10">
        <h2 class="fw-bold adaptive-text mb-1">
            <i class="bi bi-gear-wide-connected me-2"></i>System Settings
        </h2>
        <p class="adaptive-muted mb-0 small">Customize your workspace and manage security preferences.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 adaptive-card">
                <div class="card-header bg-transparent border-0 p-4 pb-0">
                    <h5 class="fw-bold adaptive-text mb-0"><i class="bi bi-palette me-2"></i>Appearance</h5>
                </div>
                <div class="card-body p-4">
                    <p class="adaptive-muted small mb-4">Choose how the dashboard looks to you.</p>

                    <div class="d-flex align-items-center justify-content-between p-3 rounded-3 mb-3 bg-adaptive-light border border-opacity-10">
                        <div>
                            <h6 class="mb-0 fw-bold adaptive-text">Dark Mode</h6>
                            <small class="adaptive-muted">Switch to a dark color palette</small>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input fs-3 cursor-pointer theme-switch" type="checkbox" id="darkModeToggle">
                        </div>
                    </div>

                    <div class="p-3 rounded-3 bg-adaptive-light border border-opacity-10">
                        <h6 class="mb-3 fw-bold adaptive-text">Accent Color</h6>
                        <div class="d-flex gap-3">
                            <div class="color-picker bg-dark active" title="Default Dark"></div>
                            <div class="color-picker bg-primary" title="Ocean Blue"></div>
                            <div class="color-picker bg-success" title="Forest Green"></div>
                            <div class="color-picker bg-info" title="Soft Cyan"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 adaptive-card">
                <div class="card-header bg-transparent border-0 p-4 pb-0">
                    <h5 class="fw-bold adaptive-text mb-0"><i class="bi bi-shield-lock me-2"></i>Security</h5>
                </div>
                <div class="card-body p-4">
                    <p class="adaptive-muted small mb-4">Manage your account protection.</p>

                    <div class="mb-4">
                        <label class="form-label small fw-bold adaptive-text opacity-75">Current Admin Email</label>
                        <div class="input-group">
                            <span class="input-group-text bg-adaptive-light border-0"><i class="bi bi-envelope"></i></span>
                            <input type="text" class="form-control bg-adaptive-light border-0 adaptive-text" value="admin@example.com" readonly>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button class="btn btn-outline-primary rounded-3 py-2 action-btn">
                            <i class="bi bi-key me-2"></i>Update Password
                        </button>
                        <button class="btn btn-outline-danger rounded-3 py-2 action-btn">
                            <i class="bi bi-trash me-2"></i>Clear Session Cache
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* --- Lush Adaptive Styles --- */
    .adaptive-header {
        background: linear-gradient(135deg, #f8faff 0%, #ffffff 100%) !important;
        border: 1px solid #eef2f6 !important;
    }

    .adaptive-card {
        background-color: #ffffff !important;
    }

    .adaptive-text {
        color: #1362b1 !important;
    }

    .adaptive-muted {
        color: #5a7184 !important;
    }

    .bg-adaptive-light {
        background-color: #f1f4f9 !important;
    }

    /* Dark Mode Support */
    [data-bs-theme="dark"] .adaptive-header,
    [data-bs-theme="dark"] .adaptive-card {
        background: #242424 !important;
        border: none !important;
    }

    [data-bs-theme="dark"] .adaptive-text {
        color: #f8f9fa !important;
    }

    [data-bs-theme="dark"] .bg-adaptive-light {
        background-color: #2d2d2d !important;
    }

    [data-bs-theme="dark"] .adaptive-muted {
        color: #adb5bd !important;
    }

    /* Theme Toggle Customization */
    .theme-switch:checked {
        background-color: #6610f2;
        border-color: #6610f2;
    }

    /* Color Picker Dots */
    .color-picker {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        cursor: pointer;
        border: 3px solid transparent;
        transition: all 0.2s;
    }

        .color-picker:hover {
            transform: scale(1.1);
        }

        .color-picker.active {
            border-color: #1362b1;
            box-shadow: 0 0 10px rgba(19,98,177,0.2);
        }

    .action-btn {
        transition: all 0.2s;
        border-width: 1.5px;
    }

        .action-btn:hover {
            transform: translateY(-2px);
        }
</style>

@section Scripts {
    <script>
        const modeToggle = document.getElementById('darkModeToggle');
        const body = document.body;

        // Initialize theme from localStorage
        if (localStorage.getItem('theme') === 'dark') {
            body.setAttribute('data-bs-theme', 'dark');
            modeToggle.checked = true;
        }

        modeToggle.addEventListener('change', () => {
            const isDark = modeToggle.checked;
            body.setAttribute('data-bs-theme', isDark ? 'dark' : 'light');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });

        // Simple Active State for Color Pickers
        document.querySelectorAll('.color-picker').forEach(picker => {
            picker.addEventListener('click', function() {
                document.querySelectorAll('.color-picker').forEach(p => p.classList.remove('active'));
                this.classList.add('active');
            });
        });
    </script>
}